{
  "name": "vitepress-plugin-crosslinks",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "description": "VitePress plugin for resolving cross-project documentation links at build time",
  "author": "Jure Erznožnik",
  "files": [
    "dist/*"
  ],
  "main": "dist/vitepress-plugin-crosslinks.umd.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/vitepress-plugin-crosslinks.umd.cjs",
      "import": "./dist/vitepress-plugin-crosslinks.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run --coverage",
    "lint": "eslint src --fix && tsc --noEmit"
  },
  "keywords": [
    "vitepress",
    "dynamicforms",
    "plugin",
    "crosslinks",
    "documentation"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:velis74/vitepress-plugin-crosslinks.git"
  },
  "issues": "https://github.com/velis74/vitepress-plugin-crosslinks/issues",
  "devDependencies": {
    "@types/markdown-it": "^14",
    "@types/node": "^24.5.2",
    "@vitest/coverage-v8": "^3",
    "eslint-config-velis": "^2.0.11",
    "markdown-it": "^14",
    "rollup-plugin-visualizer": "^5.14.0",
    "typescript": "^5",
    "vite": "^7",
    "vite-plugin-dts": "^4",
    "vite-plugin-eslint": "^1.8.1",
    "vitest": "^3"
  }
}
